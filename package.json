  "author": "qwqlang465-gif",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/qwqlang465-gif/QL-.git"
  },
  "homepage": "https://github.com/qwqlang465-gif/QL-#readme",
  "bugs": {
