{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QL",
  "version": "0.5.0",
  "identifier": "com.qwqlang465.ql",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QL",
        "width": 1100,
        "height": 820,
        "minWidth": 390,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
